# DocMind Agent — 환경 변수 예시
#
# 사용법:
#   1. 이 파일을 `.env.local` 로 복사 (`cp .env.example .env.local`)
#   2. 각 값을 실제 발급받은 키/URL 로 채움
#   3. `.env.local` 은 절대 커밋하지 말 것 (.gitignore 에 포함됨)
#
# 발급 절차: docs/IMPLEMENTATION_PLAN.md §15 Phase 0 체크리스트 참조
# 전체 키 목록: docs/IMPLEMENTATION_PLAN.md §12
#
# 표기 규칙:
#   - NEXT_PUBLIC_* : 브라우저에 노출 OK
#   - 그 외 모든 키 : 서버 전용. 클라이언트 코드에서 절대 import 금지
#
# ─────────────────────────────────────────────────────────────────
# UI-only 데모 모드 (발표·데모 종료 후 비용/만료 서비스 끊기)
# ─────────────────────────────────────────────────────────────────
# 1 로 켜면 인터뷰는 정해진 질문/답변, 문서 생성은 고정 슬라이드, Inngest 발화는
# no-op 으로 단락된다. 이 모드에선 아래 4개 키를 모두 비워도(삭제해도) 앱이 뜬다:
#   ANTHROPIC_API_KEY · VOYAGE_API_KEY · INNGEST_EVENT_KEY · INNGEST_SIGNING_KEY
#   (+ Sentry: SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN 비우면 init 스킵)
# Supabase(DB/Storage)·Google 로그인은 그대로 둬야 기존 데이터가 화면에 보인다.
DEMO_UI_ONLY=1


# ─────────────────────────────────────────────────────────────────
# Auth (Auth.js v5 + Google OAuth)
# ─────────────────────────────────────────────────────────────────

# Auth.js 세션 암호화 키. 생성: `openssl rand -base64 32`
AUTH_SECRET=your-base64-secret-here

# Google Cloud Console > OAuth 2.0 Client ID
# Type: Web application
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=1234567890-xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# 회원가입 허용 도메인. signIn 콜백에서 `profile.hd` 검증에 사용
ALLOWED_EMAIL_DOMAIN=pentasecurity.com

# 앱 공개 URL. OAuth redirect, Slack 딥링크 등에서 base URL 로 사용
# 로컬: http://localhost:3000
# 프로덕션: https://docmind.pentasecurity.com (또는 Vercel 도메인)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────
# Supabase (Postgres + Storage + pgvector)
# ─────────────────────────────────────────────────────────────────
# 발급: Supabase 콘솔 > Project Settings > API / Database

# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# 익명 키. 클라에서 쓰지 않을 거지만 SDK 초기화에 필요할 수 있음
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# 서비스 롤 키. RLS 우회. 서버 전용. 절대 클라에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# 앱 런타임용 Supavisor pooler URL (port 6543 / transaction mode)
# 형식: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# 주의: postgres-js 옵션에 `prepare: false` 반드시 (CLAUDE.md §8 함정)
SUPABASE_DB_URL=postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# Direct connection URL (port 5432) — 원안: 마이그레이션/어드민 작업용.
# 현재 미사용: Supabase Free tier 의 Direct 호스트는 IPv6-only 라 IPv4 환경에서 ENOTFOUND.
# 모든 작업이 위 SUPABASE_DB_URL (Pooler, prepare:false) 로 통일. Vercel 배포 후 IPv6 동작 시 재검토.
SUPABASE_DB_URL_DIRECT=postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Storage 버킷명. 사전에 콘솔에서 Private 으로 생성
SUPABASE_BUCKET_SOURCES=docmind-sources
SUPABASE_BUCKET_PPTX=docmind-pptx-cache


# ─────────────────────────────────────────────────────────────────
# AI (LLM + 임베딩)
# ─────────────────────────────────────────────────────────────────

# Anthropic API Key. console.anthropic.com > Settings > API Keys
# Sonnet 4.6 기본, Opus 4.7 보조 모델에 사용 (모델 ID 는 코드에서 지정)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Voyage AI Key. voyageai.com > Dashboard
# voyage-3 (1024차원) 임베딩에 사용
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────
# 백그라운드 잡 (Inngest)
# ─────────────────────────────────────────────────────────────────
# 발급: inngest.com > 앱 `docmind` > Settings > Keys
# 로컬 개발(`inngest-cli dev`)에서는 비워두어도 동작

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────
# 알림 (Slack + Email)
# ─────────────────────────────────────────────────────────────────

# Slack Bot Token. App 생성 후 워크스페이스 설치
# Scopes 필요: chat:write, chat:write.public, files:write (옵션)
SLACK_BOT_TOKEN=xoxb-0000000000-0000000000-xxxxxxxxxxxxxxxxxxxxxxxx

# 기본 발송 채널 ID (C0xxxxxx 형식, 채널명 아님)
# 채널 우클릭 > "View channel details" > 하단의 Channel ID 복사
SLACK_DEFAULT_CHANNEL_ID=C0XXXXXXXXX

# Resend API Key. resend.com > API Keys
# 발신 도메인 검증 필요 (Domains > Add Domain)
RESEND_API_KEY=re_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxx

# 발신 주소. 검증된 도메인 사용. 미설정 시 resend 테스트 발신지(onboarding@resend.dev)로 폴백
# (테스트 발신지는 Resend 계정 소유자 이메일로만 전송 가능)
RESEND_FROM=DocMind <noreply@docmind.pentasecurity.com>


# ─────────────────────────────────────────────────────────────────
# 옵저버빌리티 (Sentry)
# ─────────────────────────────────────────────────────────────────

# Sentry DSN — 트라이얼 종료 후 연결 해제됨. 이제 하드코딩이 아니라 env 가드:
#   - 서버/엣지(sentry.server.config.ts / sentry.edge.config.ts): SENTRY_DSN 있을 때만 init
#   - 클라이언트(src/instrumentation-client.ts): NEXT_PUBLIC_SENTRY_DSN 있을 때만 init
#   - 빌드 래퍼 withSentryConfig 는 next.config.ts 에서 제거(소스맵 업로드 비활성)
# 둘 다 비워두면 Sentry 완전 비활성. 복원하려면 값 채우고 next.config 래퍼 복구.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
